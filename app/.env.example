# Подключение к Postgres
DATABASE_URI=postgres://osnova:osnova@localhost:5432/osnova

# Секрет Payload — сгенерировать длинной случайной строкой
# Пример: openssl rand -hex 32
PAYLOAD_SECRET=replace-me-with-long-random-string

# URL сайта (без слеша в конце)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# SMTP для отправки писем (восстановление пароля и т.п.)
# Если SMTP_HOST не задан — письма не отправляются, попытки пишутся в консоль.
#SMTP_HOST=smtp.example.com
#SMTP_PORT=587
#SMTP_SECURE=false
#SMTP_USER=
#SMTP_PASSWORD=
#SMTP_FROM_ADDRESS=noreply@example.com
#SMTP_FROM_NAME=Osnova
