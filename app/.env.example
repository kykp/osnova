# Подключение к Postgres
DATABASE_URI=postgres://osnova:osnova@localhost:5432/osnova

# Секрет Payload — сгенерировать длинной случайной строкой
# Пример: openssl rand -hex 32
PAYLOAD_SECRET=replace-me-with-long-random-string

# URL сайта (без слеша в конце)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
